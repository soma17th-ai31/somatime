# === Backend ===
DATABASE_URL=sqlite:///./somameet.db
SESSION_SECRET=
APP_BASE_URL=http://localhost:5173
# Comma-separated extra CORS origins (e.g., Vercel preview domains).
CORS_EXTRA_ORIGINS=

# Cookie attrs. Defaults are dev-friendly (lax + http).
# Production cross-origin (Vercel FE -> Railway BE): set COOKIE_SAMESITE=none and COOKIE_SECURE=true.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Google OAuth (Calendar free/busy only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/calendar.freebusy

# LLM
LLM_PROVIDER=template
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === Production deployment hints ===
# Railway: DATABASE_URL=<auto-injected by Postgres plugin>
#          GOOGLE_REDIRECT_URI=https://<railway-domain>/api/auth/google/callback
#          APP_BASE_URL=https://<vercel-domain>
#          COOKIE_SAMESITE=none
#          COOKIE_SECURE=true
# Vercel:  VITE_API_BASE_URL=https://<railway-domain>
