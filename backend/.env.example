# === Backend ===
DATABASE_URL=sqlite:///./somameet.db
# SESSION_SECRET is reserved for future signed-state needs. Leave blank in dev;
# pick a 32+ character random value in production.
SESSION_SECRET=
APP_BASE_URL=http://localhost:5173
# Comma-separated extra CORS origins (e.g., Vercel preview domains).
CORS_EXTRA_ORIGINS=

# Cookie attrs. Defaults are dev-friendly (lax + http).
# Production cross-origin (Vercel FE -> Railway BE): set COOKIE_SAMESITE=none and COOKIE_SECURE=true.
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# === LLM ===
# Two providers are supported in v3:
#   template -> deterministic, no network call. Default for fresh clones / E1.
#   upstage  -> Upstage solar-pro3 via OpenAI-compatible SDK. Requires UPSTAGE_API_KEY.
LLM_PROVIDER=template
UPSTAGE_API_KEY=
UPSTAGE_BASE_URL=https://api.upstage.ai/v1
UPSTAGE_MODEL=solar-pro3
UPSTAGE_TIMEOUT_SECONDS=45

# Privacy note: with LLM_PROVIDER=upstage, only meeting metadata + deterministic
# candidate windows are sent to the model. NEVER raw busy_block titles / descriptions /
# locations. The privacy invariant is asserted in tests (S11) and in app/services/llm/base.py.

# === Production deployment hints ===
# Railway: DATABASE_URL=<auto-injected by Postgres plugin>
#          APP_BASE_URL=https://<vercel-domain>
#          COOKIE_SAMESITE=none
#          COOKIE_SECURE=true
# Vercel:  VITE_API_BASE_URL=https://<railway-domain>
